# Core Settings
SECRET_KEY="your-super-secret-key-here"
DEBUG=False
LOG_LEVEL="INFO"
ALLOWED_HOSTS=["pec.chatbotintegracar.online"]
CSRF_TRUSTED_ORIGINS=["https://pec.chatbotintegracar.online"]

# Database
# SQLite em volume Docker no deploy
DATABASE_URL="sqlite:////code/data/db.sqlite3"
# PostgreSQL example
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Security Settings (Set to True in production with HTTPS)
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Media Storage (S3-compatible bucket)
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_ENDPOINT_URL="https://your-s3-endpoint"
AWS_S3_REGION_NAME="your-region"
AWS_STORAGE_BUCKET_NAME="your-bucket-name"
